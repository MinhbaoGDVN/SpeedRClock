<Window x:Class="SpeedRClock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpeedRClock"
        mc:Ignorable="d"
        Title="SpeedRClock" Height="185" Width="335" ResizeMode="NoResize" Topmost="True">
    <Grid Background="#111111">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock x:Name="TimeDisplay"
                   Text="00:00:00:00.000"
                   FontSize="40"
                   Foreground="#FF09C809"
                   Height="59" Width="270"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="43" Width="275">
                <Button Content="Start" Width="80" Margin="5" Click="Start_Click"/>
                <Button Content="Pause" Width="80" Margin="5" Click="Pause_Click"/>
                <Button Content="Reset" Width="80" Margin="5" Click="Reset_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
